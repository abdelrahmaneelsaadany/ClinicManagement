{
  "$schema": "https://schema.railway.app/railway-schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet publish ClinicManagement.Api/ClinicManagement.Api.csproj -c Release -o out"
  },
  "deploy": {
    "startCommand": "dotnet out/ClinicManagement.Api.dll",
    "restartPolicyType": "ON_FAILURE"
  }
}